# ============================================
# FinRobot Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!

# -------------------------------------------
# Data Providers
# -------------------------------------------
CP=

# -------------------------------------------
# LLM (optional - for opencode feedback)
# -------------------------------------------
NV=
NVIDIA_MODEL=qwen/qwen3-235b-a22b

# -------------------------------------------
# Market Defaults
# -------------------------------------------
OKX_SYMBOL=XAU/USD
OKX_BAR=5m

# -------------------------------------------
# MetaTrader 5 (optional - Daemon 1 XAUUSD)
# -------------------------------------------
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# -------------------------------------------
# cTrader (optional - alternative executor)
# -------------------------------------------
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID=

# -------------------------------------------
# Hyperliquid - Moonshot Daemon (Daemon 2)
# -------------------------------------------
# TRADING_MODE: "paper" (default) or "live"
# WARNING: "live" uses REAL funds. Start with paper!
TRADING_MODE=paper

# Your wallet private key (0x...) - REQUIRED for live trading
# Use a DEDICATED trading wallet, not your main wallet!
HYPERLIQUID_PRIVATE_KEY=

# Your wallet address (0x...) - REQUIRED for live trading
HYPERLIQUID_WALLET_ADDRESS=

# Network: "mainnet" or "testnet" (testnet uses testnet funds)
HYPERLIQUID_NETWORK=mainnet

# API URL (override only if using custom endpoint)
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# -------------------------------------------
# Live Trading Risk Limits (only used in live mode)
# -------------------------------------------
# Maximum position size in USD
LIVE_MAX_POSITION_USD=50

# Maximum leverage used by both paper and live daemon
MAX_LEVERAGE=3

# Risk per trade as fraction of available balance (0.005 = 0.5%)
RISK_PER_TRADE_PCT=0.005

# Minimum signal confidence required to enter
MIN_CONFIDENCE=0.72

# Maximum simultaneous open positions
MAX_OPEN_POSITIONS=3

# Cooldown between entry batches
TRADE_COOLDOWN_SECONDS=15

# Maximum position duration in seconds. 0 disables timeouts.
MAX_POSITION_DURATION_SECONDS=0

# Daily loss limit as percentage of starting balance (1.0 = 1%)
DAILY_LOSS_LIMIT_PCT=1.0

# Maximum drawdown pause threshold as fraction of peak equity
MAX_DRAWDOWN_PCT=0.25

# -------------------------------------------
# Adaptive ensemble (Layer 2+3+5) - opt-in
# -------------------------------------------
# Turn on Chandelier ATR trailing stop + 1R partial TP + breakeven move.
ADAPTIVE_EXITS_ENABLED=false
# Chandelier trail = CHANDELIER_ATR_MULT * ATR (only when ADAPTIVE_EXITS_ENABLED=true).
CHANDELIER_ATR_MULT=2.5
# When true, the partial-TP trigger fires at 1R instead of the legacy default.
PARTIAL_TP_AT_1R=false

# Regime-aware Bayesian edge gate. Blocks strategies that have lost their
# edge in the current regime (uses online posteriors over win rate + R).
REGIME_GATE_ENABLED=false
REGIME_GATE_MIN_TRADES=20
REGIME_GATE_MIN_EXPECTED_R=0.05
REGIME_GATE_MIN_WR=0.40
# Below this trade count, the gate is bypassed so new strategies get a chance.
REGIME_GATE_GRACE_TRADES=30

# Legacy aliases still supported:
# LIVE_MAX_LEVERAGE=3
# LIVE_DAILY_LOSS_LIMIT=2

# -------------------------------------------
# Self-Improver (LLM strategist loop)
# -------------------------------------------
# OpenAI-compatible endpoint. Default = OpenAI cloud. Point at any compatible host.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
IMPROVER_MODEL=gpt-5.5
# How much trade history to summarise per LLM call
IMPROVER_WINDOW_HOURS=24
# How often the improver wakes up
IMPROVER_INTERVAL_MINUTES=60
# Minimum trades in the window to attempt a proposal (otherwise skip)
IMPROVER_MIN_TRADES=8
